# AI Model APIs (Required)
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key-here

# LLM Provider Selection (openai, gemini, or anthropic)
LLM_PROVIDER=gemini

# Web Search & Data
SERPAPI_KEY=your-serpapi-key-here
GOOGLE_TRENDS_API_KEY=your-google-trends-key

# Database Configuration
DATABASE_URL=sqlite:///./data/agents.db
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://user:password@localhost:5432/ai_agents

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Celery Task Queue
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agents.log
LOG_FORMAT=json

# Storage Paths
REPORTS_DIR=reports
GENERATED_CODE_DIR=generated_projects
DATA_DIR=data
TEMP_DIR=temp

# Agent Configuration
MAX_PARALLEL_AGENTS=5
AGENT_TIMEOUT_SECONDS=300
MAX_RETRIES=3
DEFAULT_MODEL=gpt-4-turbo-preview

# Feature Flags
ENABLE_WEB_SCRAPING=true
ENABLE_COMPETITOR_ANALYSIS=true
ENABLE_CODE_GENERATION=true
ENABLE_AUTO_DEPLOYMENT=false

# Monitoring
ENABLE_MONITORING=true
MONITORING_PORT=9090
PROMETHEUS_ENABLED=false